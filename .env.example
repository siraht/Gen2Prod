# Optional: a provider implementing Gen2Prod's structured planner HTTP contract.
GEN2PROD_MODEL_ENDPOINT=
GEN2PROD_MODEL_TOKEN=

# Optional: explicit Chrome/Chromium executable if auto-discovery fails.
GEN2PROD_BROWSER=

# Optional: override the artifact workspace.
GEN2PROD_WORKSPACE=

# Optional: Automatic.css plugin ZIP/directory override. Project configuration is used otherwise.
GEN2PROD_ACSS_SOURCE=
