{
  "name": "gen2prod",
  "version": "0.1.0",
  "description": "Measured website transformation compiler with a self-improving policy loop",
  "type": "module",
  "bin": {
    "gen2prod": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun --minify",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "cli": "bun src/cli.ts",
    "verify": "bun run check && bun test && bun run build"
  },
  "dependencies": {
    "axe-core": "^4.10.3",
    "commander": "^14.0.0",
    "culori": "^4.0.2",
    "fast-glob": "^3.3.3",
    "parse5": "^7.3.0",
    "pixelmatch": "^7.1.0",
    "playwright-core": "^1.54.1",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "sass": "^1.89.2",
    "yaml": "^2.8.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "@types/culori": "^2.1.1",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "pnpm@10.23.0"
}
